<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground"
    android:paddingVertical="10dp"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/imageThumbnail"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@color/smartroad_background"
        android:scaleType="centerCrop"
        android:contentDescription="Hazard photo" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textHazardType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:text="Hazard Type" />

        <TextView
            android:id="@+id/textDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="12sp"
            android:textColor="@color/smartroad_secondary"
            android:text="Date" />

    </LinearLayout>

    <TextView
        android:id="@+id/textStatusBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_badge_pill"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:text="New" />

</LinearLayout>
